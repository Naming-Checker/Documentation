@startuml Naming Check System Architecture

title Naming Check System - High-Level Architecture

top to bottom direction

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam component {
    BackgroundColor #E8F4F8
    BorderColor #2E86AB
    FontSize 12
    Padding 15
}
skinparam database {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
    FontSize 12
    Padding 15
}
skinparam actor {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontSize 12
}
skinparam arrow {
    FontSize 10
    Padding 10
}

actor "Lawyer" as User

component [REST API] as API
component [Text Check Service] as TextService
component [Logo Check Service\n(optional)] as LogoService
component [Offline Source Collector] as Collector

package "Internal Data Layer" #F8F9FA {
    database "Trademark DB\n(PostgreSQL)" as DB
    database "Preprocessed Naming\nStore" as Preprocessed
    component [Embedding Model] as Model
    component [Embedding Dataset] as Dataset
    component [Search Indexes] as Indexes
    database "Aggregated External\nSources (ClickHouse)" as External
}

User --> API
API --> TextService
API --> LogoService
TextService --> Preprocessed
TextService --> Indexes
TextService --> Model
TextService --> Dataset
TextService --> DB
TextService --> External
LogoService --> External
Collector --> External
TextService --> API
API --> User

note right of User
  <b>Request:</b>
  registration check
  or infringement check
end note

note right of TextService
  <b>Text flow:</b>
  - filter by Nice class
  - semantic search
  - phonetic/text search
  - similarity percentage
  - top-200 conflicts
end note

note right of Collector
  <b>Offline ingestion:</b>
  app stores, registries,
  internet sources
end note

note left of API
  <b>Response:</b>
  ranked results
  or pairwise similarity
end note

note bottom of External
  Runtime access is internal only.
  External data must be collected
  into the internal contour in advance.
end note

@enduml

